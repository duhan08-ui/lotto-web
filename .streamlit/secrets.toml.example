# Streamlit Cloud Secrets - 설정 예시 파일
# 이 파일을 복사해서 secrets.toml 로 이름을 바꾸고 실제 값을 입력하세요.
# ⚠️ secrets.toml 은 절대 GitHub에 커밋하지 마세요!
# ⚠️ TOML 규칙: [섹션] 아래에 오는 키는 전부 그 섹션 소속이 됩니다.
#    st.secrets["KEY"] 로 접근하려면 반드시 섹션 선언보다 위에 있어야 합니다.

SIMULATION_EDIT_PASSWORD = "여기에_비밀번호_입력"
DATA_CHECK_PASSWORD = "여기에_비밀번호_입력"
UNLOCK_PASSWORD = "여기에_비밀번호_입력"
LOTTO_SIMULATION_COUNT = "5000"
LOTTO_SUPABASE_URL = "https://your-project.supabase.co"
LOTTO_SUPABASE_KEY = "your-supabase-service-role-key"

# MANUS AI 분석 기능 사용 시 (선택)
# MANUS_API_KEY = "your-manus-api-key"

[persistence]
backend = "auto"
supabase_url = "https://your-project.supabase.co"
supabase_key = "your-supabase-service-role-key"
state_table = "lotto_app_state"
log_table = "lotto_log_records"
state_key = "main"
