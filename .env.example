# .env.example - 로컬 개발용 환경변수 설정 예시
# 이 파일을 복사해서 .env 로 이름을 바꾸고 실제 값을 입력하세요.
# cp .env.example .env

# ===== 필수 비밀번호 설정 =====
# 시뮬레이션 규모 변경 비밀번호
LOTTO_SIMULATION_EDIT_PASSWORD=여기에_비밀번호_입력

# 원본 데이터 접근 비밀번호
LOTTO_DATA_CHECK_PASSWORD=여기에_비밀번호_입력

# 사용 제한 해제 비밀번호
LOTTO_UNLOCK_PASSWORD=여기에_비밀번호_입력

# ===== 선택 설정 =====
# 시뮬레이션 횟수 (기본값: 5000)
LOTTO_SIMULATION_COUNT=5000

# Supabase 연동 (선택 - 영구 저장 백엔드)
LOTTO_SUPABASE_URL=https://your-project.supabase.co
LOTTO_SUPABASE_KEY=your-supabase-service-role-key

# MANUS AI 분석 기능 사용 시 (선택)
# MANUS_API_KEY=your-manus-api-key

# ===== Streamlit Cloud 배포 시 =====
# .streamlit/secrets.toml.example 파일을 참고해서
# Streamlit Cloud 앱 설정 > Secrets 메뉴에서 직접 입력하세요.
